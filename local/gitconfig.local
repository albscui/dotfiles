[user]
  email = albscui@gmail.com
  name = Albert Cui
[alias]
  co = checkout
  ci = commit
  st = status
  br = branch
  hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
[filter "lfs"]
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-proces
[core]
  excludesfile=/Users/albert/.gitignore.local
